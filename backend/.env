# ============================================
# RouteAI Backend - Environment Variables
# Salin file ini ke .env dan isi nilainya
# ============================================

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database - MongoDB Atlas (gratis tier tersedia)
# Daftar di: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb://localhost:27017/routeai

# JWT Secret - ganti dengan string random panjang
JWT_SECRET=020d0c06e24526edb76a68d6af625828f85ebb0f26cea011da88f0a5623a8c4b060baab69f17e5f04ec1ec8755a8d0cc0ee18547577dbe2f8e371d95088fe4f8
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Anthropic AI (Claude) - untuk AI Chat & analisis rute
# Daftar di: https://console.anthropic.com (free tier tersedia)
GROQ_API_KEY=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
# OpenWeatherMap API (gratis 1000 calls/hari)
# Daftar di: https://openweathermap.org/api
OPENWEATHER_API_KEY=ea2ff1c54fab5c3e7d4f27d2583d19d8

# Google OAuth (opsional, untuk login Google)
GOOGLE_CLIENT_ID=xxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# OSRM Routing - gunakan public atau self-hosted
OSRM_BASE_URL=https://router.project-osrm.org

# Nominatim Geocoding - gunakan public atau self-hosted
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# Redis (opsional, untuk caching - gunakan Redis Cloud free tier)
REDIS_URL=redis://localhost:6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Email (opsional, untuk notifikasi)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
