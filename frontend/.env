# ============================================
# RouteAI Frontend - Environment Variables
# Salin ke .env dan sesuaikan
# ============================================

# URL Backend API (ganti dengan IP server produksi Anda)
REACT_APP_API_URL=http://localhost:5000/api

# WebSocket URL
REACT_APP_WS_URL=http://localhost:5000

# Anthropic API Key (untuk AI chat langsung dari frontend)
# Ini opsional - lebih aman lewat backend
REACT_APP_GEMINI_API_KEY=AIzaSyDM97UxI6YKnfAkgGmSzX_ED6zjlvtLSYc

# OpenWeatherMap (opsional jika sudah ditangani backend)
REACT_APP_OWM_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Nama aplikasi
REACT_APP_NAME=RouteAI
REACT_APP_VERSION=1.0.0

# Default kota (untuk geocoding)
REACT_APP_DEFAULT_CITY=Palembang

# Default koordinat (Palembang)
REACT_APP_DEFAULT_LAT=-2.9761
REACT_APP_DEFAULT_LNG=104.7754
